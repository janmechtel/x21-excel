# Deno Server Environment Variables

# API Keys - Replace with your actual keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here # pragma: allowlist secret


# Langfuse Configuration - Get from https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here # pragma: allowlist secret
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_TRACING_ENVIRONMENT=debug

# PostHog Logs (OTLP)
POSTHOG_API_KEY=your_posthog_project_api_key_here # pragma: allowlist secret
POSTHOG_LOGS_ENDPOINT=https://us.i.posthog.com/i/v1/logs
# POSTHOG_LOGS_ENABLED=true

# Deno-specific settings
SERVER_PORT=8000

# X21_ENVIRONMENT=production
# X21_LOGS_ENABLED=true

DISABLE_FORMAT_REVERT=true

LLM_PROVIDER=anthropic #azure

# OpenAI Responses performance tuning
OPENAI_VERBOSE_LOGS=false
