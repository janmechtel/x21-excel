{
  "compilerOptions": {
    "lib": [
      "dom",
      "esnext",
      "deno.ns"
    ],
    "strict": true
  },
  "fmt": {
    "exclude": [
      "**/*.md"
    ]
  },
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.56.0",
    "@opentelemetry/api-logs": "npm:@opentelemetry/api-logs@^0.52.1",
    "@opentelemetry/exporter-logs-otlp-http": "npm:@opentelemetry/exporter-logs-otlp-http@^0.52.1",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^1.29.0",
    "@opentelemetry/sdk-logs": "npm:@opentelemetry/sdk-logs@^0.52.1",
    "@shared/types": "../shared/types/index.ts",
    "@std/log": "jsr:@std/log@^0.224.11",
    "@std/path": "jsr:@std/path@0.224.0",
    "diff": "npm:diff@5.1.0",
    "langfuse": "npm:langfuse@^3.38.4",
    "openai": "npm:openai@^4.73.1",
    "sqlite": "https://deno.land/x/sqlite@v3.9.1/mod.ts",
    "std/assert": "jsr:@std/assert@0.224.0"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "permissions": {
    "default": {
      "env": true,
      "net": true,
      "read": true,
      "sys": true,
      "write": true
    }
  },
  "tasks": {
    "api": "deno run -P --env-file=.env mod.ts",
    "api:3000": "deno run -P --env-file=.env mod.ts api 3000",
    "build": "deno compile -P --env-file=.env --include=src/data --target x86_64-pc-windows-msvc --output x21-backend --no-check mod.ts",
    "debug": "cmd /c \"set X21_ENVIRONMENT=Debug && deno run -P --env-file=.env --inspect-brk mod.ts\"",
    "dev": "cmd /c \"set X21_ENVIRONMENT=Debug && deno run -P --env-file=.env --watch --no-clear-screen mod.ts\"",
    "dev-api": "cmd /c \"set X21_ENVIRONMENT=Debug && deno run -P --env-file=.env --watch --no-clear-screen mod.ts api \"",
    "start": "deno run -P --env-file=.env mod.ts"
  }
}
