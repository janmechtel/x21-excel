# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for Deno/TypeScript files (Deno fmt uses LF)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Windows-specific files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# C# files can use CRLF (Visual Studio default)
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
